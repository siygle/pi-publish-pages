{
  "name": "pi-publish-pages",
  "version": "0.1.0",
  "description": "Telegraph (telegra.ph) wrapper extension for pi. Publish, update, delete (soft-delete) pages via Telegraph API.",
  "type": "module",
  "main": "dist/index.js",
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "latest",
    "@mariozechner/pi-coding-agent": "latest",
    "@mariozechner/pi-tui": "latest",
    "@sinclair/typebox": "^0.34.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "files": [
    "dist",
    "scripts",
    "README.md"
  ],
  "keywords": [
    "pi",
    "extension",
    "telegraph",
    "publish",
    "markdown"
  ],
  "license": "MIT"
}
